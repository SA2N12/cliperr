{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2023"],
    "types": ["node"],
    "strict": true,
    "noEmit": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true,
    "forceConsistentCasingInFileNames": true
  },
  "include": ["server/**/*.ts", "src/main/**/*.ts", "src/shared/**/*.ts"],
  "exclude": ["node_modules", "src/main/index.ts", "src/main/ipc.ts", "src/main/media.ts", "src/main/secrets.ts", "src/main/paths.ts", "src/main/scheduler.ts", "src/main/publish/service.ts"]
}
