# Copie ce fichier en `.env` et remplis les valeurs.

# Mot de passe d'accès au dashboard (login mono-utilisateur).
ADMIN_PASSWORD=change-moi-mot-de-passe-fort

# Clé maîtresse : signe les sessions + chiffre les secrets (clé API, tokens TikTok).
# Génère-la, garde-la secrète, ne la change pas (sinon les secrets stockés deviennent illisibles).
# Ex (Linux/macOS) : openssl rand -hex 32
SECRET_KEY=remplace-par-une-longue-chaine-aleatoire-min-16

# Domaine du dashboard (pour HTTPS via Caddy en prod). Ex : clip.mondomaine.com
# Le DNS de ce domaine doit pointer (A record) vers l'IP du VPS.
DOMAIN=clip.mondomaine.com
